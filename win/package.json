{
  "name": "ek-streamdl-windows",
  "version": "0.9.0",
  "buildVersion": "11",
  "private": true,
  "author": "唐梓耀 (Emir Kaya)",
  "type": "module",
  "description": "EK StreamDL for Windows x64",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:web": "vite --host 127.0.0.1",
    "dev": "pnpm run build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "pnpm run build && electron .",
    "build:web": "tsc --noEmit && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "pnpm run build:web && pnpm run build:electron",
    "test": "vitest run",
    "dist:win": "pnpm run build && electron-builder --win zip nsis --x64",
    "dist:win:dir": "pnpm run build && electron-builder --win dir --x64"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.tang1206cc.ekstreamdl",
    "productName": "EK StreamDL",
    "artifactName": "windows-x64-EK StreamDL-${version}.${ext}",
    "directories": {
      "output": "build-output"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "public/app-icon.png",
      "publisherName": "Tang Ziyao"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EK StreamDL"
    }
  }
}
